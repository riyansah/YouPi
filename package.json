{
  "name": "personal-activity-dashboard",
  "version": "0.7.59",
  "private": true,
  "scripts": {
    "dev": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/next/dist/bin/next dev",
    "setup": "./launcher.sh",
    "build": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/next/dist/bin/next build",
    "start": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/next/dist/bin/next start",
    "typecheck": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/typescript/bin/tsc --noEmit --project tsconfig.typecheck.json",
    "test": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/tsx/dist/cli.mjs --test tests/*.test.ts",
    "prepare:commit": "npm run test && npm run lint && npm run typecheck && npm run build",
    "lint": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/eslint/bin/eslint.js .",
    "auth:reset": "TZ=Asia/Jakarta ./scripts/node.sh ./node_modules/tsx/dist/cli.mjs scripts/reset-auth.ts"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
