            "name": "view",
            "in": "query",
            "schema": {
              "enum": [
                "today",
                "week",
                "month",
                "agenda"
              ],
              "default": "today"
            }
          },
          {
            "name": "anchorDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "source",
            "in": "query",
            "schema": {
              "enum": [
                "all",
                "work",
                "activity",
                "routine"
              ],
              "default": "all"
            }
          },
          {
            "name": "status",
            "in": "query",
