{
  "openapi": "3.1.0",
  "info": {
    "title": "YouPi REST API",
    "version": "0.7.65"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3000"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "activity_session"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "status",
          "priority",
          "startDate",
          "deadline",
          "startTime",
          "endTime",
          "completedAt",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "enum": [
              "Akan Datang",
              "Berjalan",
              "Selesai",
              "Tertunda",
              "Dibatalkan"
            ]
          },
          "priority": {
            "enum": [
              "Rendah",
              "Sedang",
              "Tinggi"
            ]
          },
          "startDate": {
            "type": "string"
          },
          "deadline": {
            "type": "string"
          },
          "startTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "endTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "completedAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Activity": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "date",
          "startTime",
          "endTime",
          "status",
          "notes",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "enum": [
              "Kerja",
              "Belajar",
              "Olahraga",
              "Istirahat",
              "Meeting",
              "Project Pribadi",
              "Lainnya"
            ]
          },
          "date": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "status": {
            "enum": [
              "Akan Datang",
              "Direncanakan",
              "Berjalan",
              "Selesai",
              "Tertunda",
              "Dibatalkan"
            ]
          },
          "notes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Routine": {
        "type": "object",
        "required": [
          "id",
          "title",
          "days",
          "startTime",
          "endTime",
          "priority",
          "notes",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "days": {
            "type": "array",
            "items": {
              "enum": [
                "Senin",
                "Selasa",
                "Rabu",
                "Kamis",
                "Jumat",
                "Sabtu",
                "Minggu"
              ]
            }
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "priority": {
            "enum": [
              "Rendah",
              "Sedang",
              "Tinggi"
            ]
          },
          "notes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Note": {
        "type": "object",
        "required": [
          "id",
          "title",
          "content",
          "category",
          "linkedType",
          "linkedId",
          "tags",
          "isPinned",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
            "enum": [
              "work",
              "activity",
              "routine",
              "personal"
            ]
          },
          "linkedType": {
            "enum": [
              "work",
              "activity",
              "routine",
              null
            ]
          },
          "linkedId": {
            "type": [
              "string",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isPinned": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Settings": {
        "type": "object",
        "required": [
          "dashboardName",
          "theme",
          "language",
          "timeZone"
        ],
        "properties": {
          "dashboardName": {
            "type": "string"
          },
          "theme": {
            "enum": [
              "Terang",
              "Gelap",
              "Sistem"
            ]
          },
          "language": {
            "enum": [
              "en",
              "id"
            ]
          },
          "timeZone": {
            "type": "string"
          }
        }
      },
      "HistoryEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "eventType": {
            "enum": [
              "created",
              "updated",
              "completed",
              "missed",
              "cancelled",
              "deleted",
              "pinned",
              "unpinned"
            ]
          },
          "entityType": {
            "enum": [
              "work",
              "activity",
              "routine",
              "note"
            ]
          },
          "entityId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "metadata": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        }
      },
      "DashboardBackup": {
        "type": "object",
        "description": "Versions 1-6 are supported. Routines are required for v2+, notes for v4+, and history for v5+.",
        "required": [
          "version",
          "exportedAt",
          "tasks",
          "activities",
          "settings"
        ],
        "properties": {
          "version": {
            "type": "integer",
            "enum": [1, 2, 3, 4, 5, 6]
          },
          "exportedAt": {
            "type": "string",
            "format": "date-time"
          },
          "tasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "activities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          },
          "routines": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Routine"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Note"
            }
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HistoryEvent"
            }
          },
          "settings": {
            "$ref": "#/components/schemas/Settings"
          }
        }
      },
      "ScheduleItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "source": {
            "enum": [
              "work",
              "activity",
              "routine"
            ]
          },
          "sourceId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "startTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "endTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "displayStatus": {
            "enum": [
              "upcoming",
              "done",
              "missed",
              "cancelled"
            ]
          },
          "href": {
            "type": "string"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "ReportExportModel": {
        "type": "object",
        "properties": {
          "period": {
            "enum": [
              "Harian",
              "Mingguan",
              "Bulanan"
            ]
          },
          "periodLabel": {
            "type": "string"
          },
          "selectedDate": {
            "type": "string"
          },
          "generatedAt": {
            "type": "string"
          },
          "filteredTasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "filteredActivities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "insights": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/status": {
      "get": {
        "security": [],
        "summary": "Read registration and session status",
        "responses": {
          "200": {
            "description": "Current auth status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "registered",
                    "authenticated",
                    "user"
                  ],
                  "properties": {
                    "registered": {
                      "type": "boolean"
                    },
                    "authenticated": {
                      "type": "boolean"
                    },
                    "user": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "security": [],
        "summary": "Create the single local account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account created"
          },
          "400": {
            "description": "Invalid credentials"
          },
          "409": {
            "description": "Account already exists"
          },
          "413": {
            "description": "Request body exceeds 8 KiB"
          },
          "415": {
            "description": "JSON content type required"
          },
          "429": {
            "description": "Registration rate limited"
          }
        }
      }
    },
    "/api/auth/login": {
      "get": {
        "security": [],
        "summary": "Read login lockout status",
        "responses": {
          "200": {
            "description": "Current lockout status"
          }
        }
      },
      "post": {
        "security": [],
        "summary": "Create an authenticated session",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Session created"
          },
          "401": {
            "description": "Invalid credentials"
          },
          "409": {
            "description": "No account registered"
          },
          "413": {
            "description": "Request body exceeds 8 KiB"
          },
          "415": {
            "description": "JSON content type required"
          },
          "429": {
            "description": "Login locked"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "security": [],
        "summary": "Invalidate the current session",
        "responses": {
          "200": {
            "description": "Session cleared"
          }
        }
      }
    },
    "/api/auth/change-password": {
      "post": {
        "summary": "Change the authenticated account password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "currentPassword",
                  "newPassword",
                  "confirmPassword"
                ],
                "properties": {
                  "currentPassword": {
                    "type": "string"
                  },
                  "newPassword": {
                    "type": "string"
                  },
                  "confirmPassword": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Password changed"
          },
          "400": {
            "description": "Invalid password payload"
          },
          "401": {
            "description": "Unauthorized or current password invalid"
          }
        }
      }
    },
    "/api/tasks": {
      "get": {
        "summary": "List tasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Task"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create tasks",
