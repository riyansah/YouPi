          {
            "name": "selectedDate",
            "in": "query",
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "period",
            "in": "query",
            "schema": {
              "enum": [
                "Harian",
                "Mingguan",
                "Bulanan",
                "Kustom"
              ],
              "default": "Mingguan"
            }
          },
          {
            "name": "rangeFrom",
