        "type": "object",
        "properties": {
          "period": {
            "enum": [
              "Harian",
              "Mingguan",
              "Bulanan"
            ]
          },
          "periodLabel": {
            "type": "string"
          },
          "selectedDate": {
            "type": "string"
          },
          "generatedAt": {
            "type": "string"
          },
          "filteredTasks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Task"
            }
          },
          "filteredActivities": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          },
          "metrics": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "insights": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        }
      }
    }
