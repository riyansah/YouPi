{
  "openapi": "3.1.0",
  "info": {
    "title": "YouPi REST API",
    "version": "0.7.51"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:3000"
    }
  ],
  "security": [
    {
      "cookieAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "activity_session"
      }
    },
    "schemas": {
      "Task": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "status",
          "priority",
          "startDate",
          "deadline",
          "startTime",
          "endTime",
          "completedAt",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "status": {
            "enum": [
              "Akan Datang",
              "Berjalan",
              "Selesai",
              "Tertunda",
              "Dibatalkan"
            ]
          },
          "priority": {
            "enum": [
              "Rendah",
              "Sedang",
              "Tinggi"
            ]
          },
          "startDate": {
            "type": "string"
          },
          "deadline": {
            "type": "string"
          },
          "startTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "endTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "completedAt": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Activity": {
        "type": "object",
        "required": [
          "id",
          "title",
          "category",
          "date",
          "startTime",
          "endTime",
          "status",
          "notes",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "enum": [
              "Kerja",
              "Belajar",
              "Olahraga",
              "Istirahat",
              "Meeting",
              "Project Pribadi",
              "Lainnya"
            ]
          },
          "date": {
            "type": "string"
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "status": {
            "enum": [
              "Akan Datang",
              "Direncanakan",
              "Berjalan",
              "Selesai",
              "Tertunda",
              "Dibatalkan"
            ]
          },
          "notes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Routine": {
        "type": "object",
        "required": [
          "id",
          "title",
          "days",
          "startTime",
          "endTime",
          "priority",
          "notes",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "days": {
            "type": "array",
            "items": {
              "enum": [
                "Senin",
                "Selasa",
                "Rabu",
                "Kamis",
                "Jumat",
                "Sabtu",
                "Minggu"
              ]
            }
          },
          "startTime": {
            "type": "string"
          },
          "endTime": {
            "type": "string"
          },
          "priority": {
            "enum": [
              "Rendah",
              "Sedang",
              "Tinggi"
            ]
          },
          "notes": {
            "type": "string"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Note": {
        "type": "object",
        "required": [
          "id",
          "title",
          "content",
          "category",
          "linkedType",
          "linkedId",
          "tags",
          "isPinned",
          "createdAt",
          "updatedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "category": {
            "enum": [
              "work",
              "activity",
              "routine",
              "personal"
            ]
          },
          "linkedType": {
            "enum": [
              "work",
              "activity",
              "routine",
              null
            ]
          },
          "linkedId": {
            "type": [
              "string",
              "null"
            ]
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isPinned": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        }
      },
      "Settings": {
        "type": "object",
        "required": [
          "dashboardName",
          "theme",
          "preferredCategories",
          "language",
          "timeZone"
        ],
        "properties": {
          "dashboardName": {
            "type": "string"
          },
          "theme": {
            "enum": [
              "Terang",
              "Gelap",
              "Sistem"
            ]
          },
          "preferredCategories": {
            "type": "array",
            "items": {
              "enum": [
                "Kerja",
                "Belajar",
                "Olahraga",
                "Istirahat",
                "Meeting",
                "Project Pribadi",
                "Lainnya"
              ]
            }
          },
          "language": {
            "enum": [
              "en",
              "id"
            ]
          },
          "timeZone": {
            "type": "string"
          }
        }
      },
      "HistoryEvent": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "eventType": {
            "enum": [
              "created",
              "updated",
              "completed",
              "missed",
              "cancelled",
              "deleted",
              "pinned",
              "unpinned"
            ]
          },
          "entityType": {
            "enum": [
              "work",
              "activity",
              "routine",
              "note"
            ]
          },
          "entityId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "metadata": {
            "type": [
              "string",
              "null"
            ]
          },
          "createdAt": {
            "type": "string"
          }
        }
      },
      "ScheduleItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "source": {
            "enum": [
              "work",
              "activity",
              "routine"
            ]
          },
          "sourceId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "date": {
            "type": "string"
          },
          "startTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "endTime": {
            "type": [
              "string",
              "null"
            ]
          },
          "displayStatus": {
            "enum": [
              "upcoming",
              "done",
              "missed",
              "cancelled"
            ]
          },
          "href": {
            "type": "string"
          },
          "notes": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
